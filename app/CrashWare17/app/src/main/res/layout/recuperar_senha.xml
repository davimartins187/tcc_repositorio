<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main3"
    android:fillViewport="true"
    android:background="?attr/android:windowBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="32dp"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/layoutLogo"
                android:layout_width="56dp"
                android:layout_height="61dp"
                android:contentDescription="logo"
                android:src="@drawable/logo_sem_fundo"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/righteous"
                android:text="CRASHWARE"
                android:textColor="?attr/colorOnSurface"
                android:textSize="25sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Título -->
        <TextView
            android:id="@+id/txtRecSenha"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="94dp"
            android:text="Redefinir SENHA"
            android:textAllCaps="true"
            android:fontFamily="@font/righteous"
            android:textColor="?attr/colorOnSurface"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/header" />

        <!-- Métodos de Recuperação -->
        <RadioGroup
            android:id="@+id/grupoOpcoes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="60dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@+id/txtRecSenha">

            <RadioButton
                android:id="@+id/radioEmail"
                android:layout_height="wrap_content"
                android:layout_width="match_parent"
                android:text="RECEBER CÓDIGO PELO E-MAIL"
                android:fontFamily="@font/righteous"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingStart="12dp"
                />

            <RadioButton
                android:id="@+id/radioTelefone"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="RECEBER CÓDIGO PELO TELEFONE"
                android:fontFamily="@font/righteous"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingStart="12dp"
                />
        </RadioGroup>

        <!-- Campo Email -->
        <EditText
            android:id="@+id/txtEmailRec"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_edittext_borda"
            android:hint="Digite o e-mail cadastrado"
            android:fontFamily="@font/pt_sans_caption_bold"
            android:paddingHorizontal="16dp"
            android:textColor="#FFFFFF"
            android:textColorHint="@color/hint_modoclaro"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/grupoOpcoes" />

        <!-- Botão de Enviar -->
        <Button
            android:id="@+id/btnRecSenha"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="25dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_button_borda"
            android:text="ENVIAR"
            app:backgroundTint="@null"
            app:backgroundTintMode="add"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:fontFamily="@font/righteous"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintHorizontal_bias="0.495"
            app:layout_constraintTop_toBottomOf="@+id/txtEmailRec" />

        <!-- Texto Entrar -->
        <TextView
            android:id="@+id/txtEntrarLembrou"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginTop="30dp"
            android:text="Entrar"
            android:textColor="#4CAF50"
            android:textSize="16sp"
            android:textStyle="bold|italic"
            app:layout_constraintStart_toEndOf="@+id/txtLembrou"
            app:layout_constraintTop_toBottomOf="@+id/btnRecSenha" />

        <!-- Lembrou sua senha? -->
        <TextView
            android:id="@+id/txtLembrou"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="90dp"
            android:layout_marginTop="30dp"
            android:text="Lembrou sua senha?"
            android:fontFamily="@font/pt_sans_caption_bold"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnRecSenha" />

        <View
            android:id="@+id/espaco_nav_bar"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            app:layout_constraintTop_toBottomOf="@id/txtLembrou" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>