<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B1C2C">

    <!-- Logo + Nome CENTRALIZADO -->
    <LinearLayout
        android:id="@+id/layoutLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="44dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/logo_sem_fundo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="CRASHWARE"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Título -->
    <TextView
        android:id="@+id/txtEntrar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ENTRAR"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="20sp"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/layoutLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Campo Email -->
    <EditText
        android:id="@+id/txtEmailLogin"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:hint="E-mail ou nome de usuário"
        android:textColor="#FFFFFF"
        android:textColorHint="#8FA3B0"
        android:textSize="14sp"
        android:background="@drawable/bg_input"
        android:padding="12dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/txtEntrar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="24dp"/>

    <!-- Campo Senha -->
    <EditText
        android:id="@+id/txtSenhaLogin"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:hint="Senha"
        android:textColor="#FFFFFF"
        android:textColorHint="#8FA3B0"
        android:textSize="14sp"
        android:background="@drawable/bg_input"
        android:padding="12dp"
        android:inputType="textPassword"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/txtEmailLogin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="24dp"/>

    <!-- Ícone de mostrar senha -->
    <ImageView
        android:id="@+id/imgOlho"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/olho_icon"
        android:layout_marginEnd="12dp"
        android:elevation="2dp"
        android:translationX="-4dp"
        app:layout_constraintEnd_toEndOf="@id/txtSenhaLogin"
        app:layout_constraintTop_toTopOf="@id/txtSenhaLogin"
        app:layout_constraintBottom_toBottomOf="@id/txtSenhaLogin"/>

    <!-- Esqueceu senha -->
    <TextView
        android:id="@+id/txtEsqueceu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Esqueceu sua senha?"
        android:textColor="#AAAAAA"
        android:textSize="12sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/txtSenhaLogin"
        app:layout_constraintEnd_toEndOf="@id/txtSenhaLogin"/>

    <!-- Botão Entrar -->
    <Button
        android:id="@+id/btnEntrar"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:text="ENTRAR"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4CAF50"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/txtEsqueceu"
        app:layout_constraintStart_toStartOf="@id/txtSenhaLogin"
        app:layout_constraintEnd_toEndOf="@id/txtSenhaLogin"/>

    <!-- OU -->
    <TextView
        android:id="@+id/txtOu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OU"
        android:textColor="#AAAAAA"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnEntrar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Botões sociais -->
    <LinearLayout
        android:id="@+id/layoutSocial"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/txtOu"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Google -->
        <ImageView
            android:id="@+id/imgGoogle"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/google_icon"
            android:contentDescription="Login com Google"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Facebook -->
        <ImageView
            android:id="@+id/imgFacebook"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:src="@drawable/facebook_icon"
            android:contentDescription="Login com Facebook"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

    <!-- Criar conta -->
    <TextView
        android:id="@+id/txtCriarConta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ainda não tem uma conta? Criar conta"
        android:textColor="#AAAAAA"
        android:textSize="12sp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>