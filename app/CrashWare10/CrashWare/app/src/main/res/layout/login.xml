<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/android:windowBackground">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/layoutLogo"
            android:layout_width="56dp"
            android:layout_height="61dp"
            android:contentDescription="logo"
            android:src="@drawable/logo_sem_fundo"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/righteous"
            android:text="CRASHWARE"
            android:textColor="?attr/colorOnSurface"
            android:textSize="25sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Título -->
    <TextView
        android:id="@+id/txtEntrar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="125dp"
        android:layout_marginTop="94dp"
        android:layout_marginEnd="125dp"
        android:fontFamily="@font/righteous"
        android:text="ENTRAR"
        android:textColor="?attr/colorOnSurface"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/header" />

    <!-- Campo Email -->

    <!-- Campo Senha -->
    <EditText
        android:id="@+id/txtEmailLogin"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="28dp"
        android:background="@drawable/bg_edittext_borda"
        android:fontFamily="@font/pt_sans_caption_bold"
        android:hint="E-mail ou nome de usuário"
        android:paddingHorizontal="16dp"
        android:textColor="#000000"
        android:textColorHint="@color/hint_modoclaro"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txtEntrar" />

    <EditText
        android:id="@+id/txtSenhaLogin"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginHorizontal="32dp"
        android:hint="Senha"
        android:fontFamily="@font/pt_sans_caption_bold"
        android:textColor="#000000"
        android:textColorHint="@color/hint_modoclaro"
        android:background="@drawable/bg_edittext_borda"
        android:padding="12dp"
        android:inputType="textPassword"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/txtEmailLogin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />

    <!-- Ícone de mostrar senha -->

    <ImageView
        android:id="@+id/imgOlho"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/olho_icon"
        android:layout_marginEnd="12dp"
        android:elevation="2dp"
        android:translationX="-4dp"
        app:layout_constraintEnd_toEndOf="@id/txtSenhaLogin"
        app:layout_constraintTop_toTopOf="@id/txtSenhaLogin"
        app:layout_constraintBottom_toBottomOf="@id/txtSenhaLogin"/>

    <!-- Esqueceu senha -->
    <TextView
        android:id="@+id/txtEsqueceu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/pt_sans_caption_bold"
        android:text="Esqueceu sua senha?"
        android:textColor="?attr/colorOnSurface"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="@id/txtSenhaLogin"
        app:layout_constraintTop_toBottomOf="@id/txtSenhaLogin" />

    <!-- Botão Entrar -->
    <Button
        android:id="@+id/btnEntrar"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="25dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_botaosborda"
        android:text="ENTRAR"
        app:backgroundTint="@null"
        app:backgroundTintMode="add"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="16sp"
        android:fontFamily="@font/righteous"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintHorizontal_bias="0.495"
        app:layout_constraintTop_toBottomOf="@id/txtEsqueceu" />

    <!-- OU -->
    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="24dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnEntrar">

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="?attr/colorOnSurface" />

        <TextView
            android:id="@+id/tvOu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:fontFamily="@font/righteous"
            android:text="ou"
            android:textColor="?attr/colorOnSurface"
            android:textSize="17sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="?attr/colorOnSurface" />
    </LinearLayout>

    <!-- Criar conta -->
    <LinearLayout
        android:id="@+id/layoutSocial"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/linearLayout" />

    <TextView
        android:id="@+id/txtCriarConta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="17dp"
        android:layout_marginBottom="350dp"
        android:fontFamily="@font/righteous"
        android:text="Não tem uma conta?"
        android:textColor="?attr/colorOnSurface"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout" />

    <Button
        android:id="@+id/btnCadLogin"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_botaosborda"
        android:text="CADASTRE-SE"
        app:backgroundTint="@null"
        app:backgroundTintMode="add"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="16sp"
        android:fontFamily="@font/righteous"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintHorizontal_bias="0.495"
        app:layout_constraintTop_toBottomOf="@id/txtCriarConta" />

</androidx.constraintlayout.widget.ConstraintLayout>