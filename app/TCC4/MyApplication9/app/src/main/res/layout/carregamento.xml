<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- LOGO SUPERIOR -->
    <ImageView
        android:id="@+id/imageView"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_marginTop="32dp"
        android:contentDescription="Logo"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/logo_sem_fundo" />

    <!-- TÍTULO -->
    <TextView
        android:id="@+id/txtCrashware"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CRASHWARE"
        android:textColor="#000000"
        android:textSize="42sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/imageView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ROBÔ -->
    <ImageView
        android:id="@+id/imgRobo"
        android:layout_width="180dp"
        android:layout_height="220dp"
        android:contentDescription="Robô"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/txtCrashware"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/chatizinho_bot" />

    <!-- TEXTO CARREGANDO -->
    <TextView
        android:id="@+id/txtCarregando"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CARREGANDO"
        android:textColor="#000000"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/imgRobo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- TRÊS PONTOS -->
    <TextView
        android:id="@+id/txtTrespontos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="..."
        android:textColor="#000000"
        android:textSize="48sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/txtCarregando"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>