<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Gradiente da bordda -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#AAEFEFEF"
                android:endColor="#AAEFEFEF"
                android:angle="270"/>
            <corners android:radius="18dp" />
        </shape>
    </item>

    <!-- Manter a mesma cor do fundo -->
    <item
        android:bottom="4dp"
        android:left="4dp"
        android:right="4dp"
        android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/bg_vidro_transparente" />
            <corners android:radius="15dp" />
        </shape>
    </item>

    <!-- Faz a "falsa transparencia" -->
    <item
        android:bottom="4dp"
        android:left="4dp"
        android:right="4dp"
        android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#25FFFFFF" />
            <corners android:radius="15dp" />
        </shape>
    </item>
</layer-list>