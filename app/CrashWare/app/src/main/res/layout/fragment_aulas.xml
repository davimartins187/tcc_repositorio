<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/fundo_claro">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Header -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:background="@color/branco"
            android:elevation="10dp"
            app:layout_constraintEnd_toStartOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Logo -->
            <ImageView
                android:id="@+id/imgLayoutLogo"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="10dp"
                android:layout_marginTop="10dp"
                android:contentDescription="logo"
                android:src="@drawable/logo_sem_fundo"
                app:layout_constraintStart_toStartOf="@id/header"
                app:layout_constraintTop_toTopOf="@id/header"/>

            <!-- Nome do App -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="10dp"
                android:layout_marginTop="5dp"
                android:fontFamily="@font/righteous"
                android:text="CRASHWARE"
                android:textColor="@color/azul"
                android:textSize="25sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/imgLayoutLogo"
                app:layout_constraintTop_toTopOf="@id/imgLayoutLogo"/>

            <!-- Sininho -->
            <ImageView
                android:id="@+id/layoutSino"
                android:layout_width="30dp"
                android:layout_height="35dp"
                android:layout_marginTop="15dp"
                android:layout_marginEnd="20dp"
                android:contentDescription="logo"
                android:src="@drawable/sino_icon"
                app:layout_constraintEnd_toEndOf="@id/header"
                app:layout_constraintTop_toTopOf="@id/header"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Escolha do percurso -->
        <TextView
            android:id="@+id/txtEscolhaAprendizagem"
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/righteous"
            android:text="Escolha um percurso de aprendizagem:"
            android:textAlignment="center"
            android:textColor="#0F172A"
            android:textSize="24sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/header" />

        <!-- Card Software -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/card"
            android:layout_width="340dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:padding="12dp"
            android:background="@drawable/bg_card"
            app:layout_constraintTop_toBottomOf="@id/txtEscolhaAprendizagem"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Imagem Software -->
            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="65dp"
                android:src="@drawable/codigo_icon"
                app:tint="@color/verde"
                app:layout_constraintStart_toStartOf="@id/card"
                app:layout_constraintTop_toTopOf="@id/card" />

            <!-- Escrito Software -->
            <TextView
                android:id="@+id/txtSoftware"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="60dp"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/inter_extrabold"
                android:text="Software"
                android:textAlignment="center"
                android:textColor="@color/verde"
                android:textSize="30sp"
                app:layout_constraintEnd_toEndOf="@id/card"
                app:layout_constraintTop_toTopOf="@id/card" />

            <!-- Barra -->
            <View
                android:id="@+id/barraS"
                android:layout_width="280dp"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:background="#0F172A"
                app:layout_constraintTop_toBottomOf="@id/txtSoftware"
                app:layout_constraintStart_toStartOf="@id/card"
                app:layout_constraintEnd_toEndOf="@id/card"/>

            <!-- Texto Explicativo -->
            <TextView
                android:id="@+id/txtExplicativoS"
                android:layout_width="270dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="10dp"
                android:fontFamily="@font/battambang"
                android:text="Este percurso apresenta os fundamentos do desenvolvimento de software e da lógica de programação utilizando JavaScript. Os módulos devem ser feitos na ordem recomendada para melhorar o aprendizado. Durante o percurso, você aprenderá conceitos essenciais de programação e dará os primeiros passos na criação de aplicações e páginas interativas."
                android:textAlignment="center"
                android:textColor="@color/azul"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="@id/card"
                app:layout_constraintStart_toStartOf="@id/card"
                app:layout_constraintTop_toBottomOf="@id/barraS"
                app:layout_constraintBottom_toTopOf="@id/btnExplorarS"/>

            <Button
                android:id="@+id/btnExplorarS"
                android:layout_width="150dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_botaosborda"
                app:backgroundTint="@null"
                app:backgroundTintMode="add"
                android:layout_marginBottom="10dp"
                android:fontFamily="@font/inter_bold"
                android:text="Explorar"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="@id/card"
                app:layout_constraintStart_toStartOf="@id/card"
                app:layout_constraintTop_toBottomOf="@id/txtExplicativoS"
                app:layout_constraintBottom_toBottomOf="@id/card" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Card Software -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/card1"
            android:layout_width="340dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:padding="12dp"
            android:background="@drawable/bg_card"
            app:layout_constraintTop_toBottomOf="@id/card"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Imagem Software -->
            <ImageView
                android:layout_width="40dp"
                android:layout_height="50dp"
                android:layout_marginStart="60dp"
                android:src="@drawable/hardware_icon"
                app:tint="@color/verde"
                app:layout_constraintStart_toStartOf="@id/card1"
                app:layout_constraintTop_toTopOf="@id/card1" />

            <!-- Escrito Software -->
            <TextView
                android:id="@+id/txtHardware"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="60dp"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/inter_extrabold"
                android:text="Hardware"
                android:textAlignment="center"
                android:textColor="@color/verde"
                android:textSize="30sp"
                app:layout_constraintEnd_toEndOf="@id/card1"
                app:layout_constraintTop_toTopOf="@id/card1" />

            <!-- Barra -->
            <View
                android:id="@+id/barraH"
                android:layout_width="280dp"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:background="#0F172A"
                app:layout_constraintTop_toBottomOf="@id/txtHardware"
                app:layout_constraintStart_toStartOf="@id/card1"
                app:layout_constraintEnd_toEndOf="@id/card1"/>

            <!-- Texto Explicativo -->
            <TextView
                android:id="@+id/txtExplicativoH"
                android:layout_width="270dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:fontFamily="@font/battambang"
                android:text="Neste percurso você irá aprender os fundamentos do hardware de computadores. Os cursos foram organizados em uma sequência para facilitar o aprendizado. Ao longo do caminho, você entenderá como funcionam os componentes de um computador, como realizar montagens e como identificar possíveis problemas de funcionamento."
                android:textAlignment="center"
                android:textColor="@color/azul"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="@id/card1"
                app:layout_constraintStart_toStartOf="@id/card1"
                app:layout_constraintTop_toBottomOf="@id/barraH" />

            <Button
                android:id="@+id/btnExplorarH"
                android:layout_width="150dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_botaosborda"
                app:backgroundTint="@null"
                app:backgroundTintMode="add"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:fontFamily="@font/inter_bold"
                android:text="Explorar"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="@id/card1"
                app:layout_constraintStart_toStartOf="@id/card1"
                app:layout_constraintTop_toBottomOf="@id/txtExplicativoH"
                app:layout_constraintBottom_toBottomOf="@id/card1" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:id="@+id/espaco_nav_bar"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            app:layout_constraintTop_toBottomOf="@id/card1" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>