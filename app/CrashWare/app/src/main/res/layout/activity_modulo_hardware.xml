                android:id="@+id/imgLivro3M3H"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="26dp"
                android:layout_marginTop="10dp"
                android:src="@drawable/aulaassistir_icon"
                app:layout_constraintEnd_toStartOf="@+id/txtTituloAula3M3H"
                app:layout_constraintStart_toStartOf="@id/cardComponentesInternos"
                app:layout_constraintTop_toBottomOf="@id/imgLivro2M3H" />

            <!-- Título Aula -->
