                android:id="@+id/imgLivro1M2H"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="26dp"
                android:layout_marginTop="10dp"
                android:src="@drawable/aulaassistir_icon"
                app:layout_constraintEnd_toStartOf="@+id/txtTituloAula1M2H"
                app:layout_constraintStart_toStartOf="@id/cardFundamentosHardware"
                app:layout_constraintTop_toBottomOf="@id/barraM2H" />

            <!-- Título Aula -->
            <TextView
