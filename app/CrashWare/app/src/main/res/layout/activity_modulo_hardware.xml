        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:id="@+id/espaco_nav_bar"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            app:layout_constraintTop_toBottomOf="@id/cardComponentesInternos" />


    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>