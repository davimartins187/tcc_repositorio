                android:id="@+id/txtTituloAula3M3H"
                android:layout_width="240dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="9dp"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="24dp"
                android:fontFamily="@font/battambang"
                android:text="Memória RAM"
                android:textColor="@color/azul"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="@id/cardComponentesInternos"
                app:layout_constraintStart_toEndOf="@+id/imgLivro3M3H"
                app:layout_constraintTop_toBottomOf="@id/txtTituloAula2M3H" />

            <!-- Imagem Livro -->
            <ImageView
                android:id="@+id/imgLivro4M3H"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="26dp"
                android:layout_marginTop="10dp"
                android:src="@drawable/aulaassistir_icon"
                app:layout_constraintEnd_toStartOf="@+id/txtTituloAula4M3H"
                app:layout_constraintStart_toStartOf="@id/cardComponentesInternos"
                app:layout_constraintTop_toBottomOf="@id/imgLivro3M3H" />

            <!-- Título Aula -->
            <TextView
                android:id="@+id/txtTituloAula4M3H"
                android:layout_width="240dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="9dp"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="24dp"
                android:fontFamily="@font/battambang"
                android:text="Armazenamento (HD e SSD)"
                android:textColor="@color/azul"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="@id/cardComponentesInternos"
                app:layout_constraintStart_toEndOf="@+id/imgLivro4M3H"
                app:layout_constraintTop_toBottomOf="@id/txtTituloAula3M3H" />

            <!-- Imagem Livro -->
