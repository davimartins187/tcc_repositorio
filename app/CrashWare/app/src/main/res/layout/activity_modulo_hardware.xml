                android:src="@drawable/aulaassistir_icon"
                app:layout_constraintEnd_toStartOf="@+id/txtTituloAula1M3H"
                app:layout_constraintStart_toStartOf="@id/cardComponentesInternos"
                app:layout_constraintTop_toBottomOf="@id/barraM3H" />

            <!-- Título Aula -->
            <TextView
                android:id="@+id/txtTituloAula1M3H"
                android:layout_width="240dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="9dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="24dp"
                android:fontFamily="@font/battambang"
                android:text="Placa-Mãe"
                android:textColor="@color/azul"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="@id/cardComponentesInternos"
                app:layout_constraintStart_toEndOf="@+id/imgLivro1M3H"
                app:layout_constraintTop_toBottomOf="@id/barraM3H" />

            <!-- Imagem Livro -->
            <ImageView
                android:id="@+id/imgLivro2M3H"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="26dp"
                android:layout_marginTop="10dp"
                android:src="@drawable/aulaassistir_icon"
                app:layout_constraintEnd_toStartOf="@+id/txtTituloAula2M3H"
                app:layout_constraintStart_toStartOf="@id/cardComponentesInternos"
                app:layout_constraintTop_toBottomOf="@id/imgLivro1M3H" />

            <!-- Título Aula -->
            <TextView
                android:id="@+id/txtTituloAula2M3H"
                android:layout_width="240dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="9dp"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="24dp"
                android:fontFamily="@font/battambang"
                android:text="Processador (CPU)"
                android:textColor="@color/azul"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="@id/cardComponentesInternos"
                app:layout_constraintStart_toEndOf="@+id/imgLivro2M3H"
                app:layout_constraintTop_toBottomOf="@id/txtTituloAula1M3H" />

            <!-- Imagem Livro -->
