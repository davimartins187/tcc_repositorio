<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/Envio"
    android:fillViewport="true"
    android:background="?attr/android:windowBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Header -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:layout_marginTop="15dp"
            android:background="@drawable/bg_gradiendtelasiniciais"
            android:elevation="10dp"
            app:layout_constraintEnd_toStartOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Logo -->
            <ImageView
                android:id="@+id/imgLayoutLogo"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:contentDescription="logo"
                android:src="@drawable/logo_icon"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="@id/header"
                app:layout_constraintTop_toTopOf="@id/header" />

            <!-- Nome do App -->
            <TextView
                android:id="@+id/txtNomeApp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                android:fontFamily="@font/orbitron_extrabold"
                android:text="CRASHWARE"
                android:textColor="@color/branco"
                android:textSize="34sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/imgLayoutLogo"
                app:layout_constraintTop_toTopOf="@id/header" />

            <!-- Slogan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="22dp"
                android:layout_marginEnd="19dp"
                android:layout_marginBottom="31dp"
                android:fontFamily="@font/righteous"
                android:text="A TECNOLOGIA NÃO É MÁGICA, É LÓGICA. "
                android:textColor="@color/branco"
                android:textSize="13sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/imgLayoutLogo"
                app:layout_constraintTop_toBottomOf="@id/txtNomeApp" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cardEfeitoVidro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="80dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_cardefeitovidro"
            android:elevation="10dp"
            android:paddingBottom="25dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/header">
            <!-- Título -->
            <TextView
                android:id="@+id/titulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="125dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="125dp"
                android:fontFamily="@font/righteous"
                android:text="Redefinir Senha"
                android:textAllCaps="true"
                android:textColor="?attr/colorOnSurface"
                android:textSize="24sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/cardEfeitoVidro" />

            <!-- Mensagem de Envio -->
            <TextView
                android:id="@+id/txtEnvioCodigo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="40dp"
                android:layout_marginTop="25dp"
                android:layout_marginEnd="40dp"
                android:fontFamily="@font/righteous"
                android:text="Clique no botão para enviarmos um código de verificação no seu email:"
                android:textAlignment="center"
                android:textColor="?attr/colorOnSurface"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="@id/cardEfeitoVidro"
                app:layout_constraintStart_toStartOf="@id/cardEfeitoVidro"
                app:layout_constraintTop_toBottomOf="@+id/titulo" />

            <!-- Email do Usuário -->
            <TextView
                android:id="@+id/txtNomeEmail"
                android:layout_width="380dp"
                android:layout_marginTop="2dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/righteous"
                android:text="Davidson@gmail.com"
                android:textAlignment="center"
                android:textColor="#126487"
                android:textSize="22sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/txtEnvioCodigo" />

            <!-- Campo Codigo de Verificação -->
            <EditText
                android:id="@+id/txtCodigoVerificacao"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginHorizontal="32dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_edittext_borda"
                android:fontFamily="@font/pt_sans_caption_bold"
                android:hint="Insira o código de verificação"
                android:paddingHorizontal="16dp"
                android:textColor="#000000"
                android:textColorHint="@color/hint_modoclaro"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/txtNomeEmail" />

            <!-- Botão Verificar -->
            <Button
                android:id="@+id/btnVerificar"
                android:layout_width="260dp"
                android:layout_height="48dp"
                android:layout_marginHorizontal="32dp"
                android:layout_marginTop="25dp"
                android:background="@drawable/bg_botaosborda"
                android:fontFamily="@font/righteous"
                android:text="Verificar"
                android:textAllCaps="true"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@null"
                app:backgroundTintMode="add"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/txtCodigoVerificacao" />

            <!-- Botão Reenviar -->
            <Button
                android:id="@+id/btnEnviar"
                android:layout_width="260dp"
                android:layout_height="48dp"
                android:layout_marginHorizontal="32dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_botaosborda"
                android:fontFamily="@font/righteous"
                android:text="Receber"
                android:textAllCaps="true"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@null"
                app:backgroundTintMode="add"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btnVerificar" />

            <!-- Tempo para Reenviar -->
            <TextView
                android:id="@+id/txtTempoEnviar"
                android:layout_width="160dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/righteous"
                android:text="Reenvio em
                29 segundos"
                android:textAlignment="center"
                android:textAllCaps="true"
                android:textColor="?attr/colorOnSurface"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/btnEnviar" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:id="@+id/espaco_nav_bar"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            app:layout_constraintTop_toBottomOf="@id/txtTempoEnviar" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>