                android:id="@+id/imgLivro3M3H"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="26dp"
                android:layout_marginTop="10dp"
                android:src="@drawable/livro2_icon"
                app:layout_constraintEnd_toStartOf="@+id/txtTituloAula3M3H"
                app:layout_constraintStart_toStartOf="@id/cardComponentesInternos"
