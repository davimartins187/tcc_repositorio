                android:textColor="@color/azul"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="@id/cardComponentesInternos"
                app:layout_constraintStart_toEndOf="@+id/imgLivro5M3H"
                app:layout_constraintTop_toBottomOf="@id/txtTituloAula4M3H" />

            <!-- Imagem Livro -->
            <ImageView
                android:id="@+id/imgLivro6M3H"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="26dp"
