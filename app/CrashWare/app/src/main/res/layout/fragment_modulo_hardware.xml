                android:layout_height="30dp"
                android:layout_marginStart="26dp"
                android:layout_marginTop="10dp"
                android:src="@drawable/livro2_icon"
                app:layout_constraintEnd_toStartOf="@+id/txtTituloAula2M2H"
                app:layout_constraintStart_toStartOf="@id/cardFundamentosHardware"
                app:layout_constraintTop_toBottomOf="@id/imgLivro1M2H" />

            <!-- Título Aula -->
            <TextView
                android:id="@+id/txtTituloAula2M2H"
                android:layout_width="240dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="9dp"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="24dp"
                android:fontFamily="@font/battambang"
                android:text="Evolução dos Computadores"
                android:textColor="@color/azul"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="@id/cardFundamentosHardware"
                app:layout_constraintStart_toEndOf="@+id/imgLivro2M2H"
                app:layout_constraintTop_toBottomOf="@id/txtTituloAula1M2H" />

            <!-- Imagem Livro -->
            <ImageView
                android:id="@+id/imgLivro3M2H"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="26dp"
                android:layout_marginTop="10dp"
                android:src="@drawable/livro2_icon"
                app:layout_constraintEnd_toStartOf="@+id/txtTituloAula3M2H"
                app:layout_constraintStart_toStartOf="@id/cardFundamentosHardware"
                app:layout_constraintTop_toBottomOf="@id/imgLivro2M2H" />

            <!-- Título Aula -->
            <TextView
                android:id="@+id/txtTituloAula3M2H"
                android:layout_width="240dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="9dp"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="24dp"
                android:fontFamily="@font/battambang"
                android:text="Arquitetura Básica (Von Neumann)"
                android:textColor="@color/azul"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="@id/cardFundamentosHardware"
                app:layout_constraintStart_toEndOf="@+id/imgLivro3M2H"
                app:layout_constraintTop_toBottomOf="@id/txtTituloAula2M2H" />

            <!-- Imagem Livro -->
            <ImageView
                android:id="@+id/imgLivro4M2H"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="26dp"
                android:layout_marginTop="10dp"
                android:src="@drawable/livro2_icon"
                app:layout_constraintEnd_toStartOf="@+id/txtTituloAula4M2H"
                app:layout_constraintStart_toStartOf="@id/cardFundamentosHardware"
                app:layout_constraintTop_toBottomOf="@id/imgLivro3M2H" />

            <!-- Título Aula -->
            <TextView
                android:id="@+id/txtTituloAula4M2H"
                android:layout_width="240dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="9dp"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="24dp"
                android:fontFamily="@font/battambang"
                android:text="Tipos de Computadores"
                android:textColor="@color/azul"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="@id/cardFundamentosHardware"
                app:layout_constraintStart_toEndOf="@+id/imgLivro4M2H"
                app:layout_constraintTop_toBottomOf="@id/txtTituloAula3M2H" />



        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Card Fundamentos de Hardware -->
