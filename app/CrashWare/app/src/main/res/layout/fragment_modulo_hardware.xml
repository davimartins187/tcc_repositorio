<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/fundo_claro">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Header -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:background="@color/branco"
            android:elevation="10dp"
            app:layout_constraintEnd_toStartOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Logo -->
            <ImageView
                android:id="@+id/imgLayoutLogo"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="10dp"
                android:layout_marginTop="10dp"
                android:contentDescription="logo"
                android:src="@drawable/logo_sem_fundo"
                app:layout_constraintStart_toStartOf="@id/header"
                app:layout_constraintTop_toTopOf="@id/header"/>

            <!-- Nome do App -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="10dp"
                android:layout_marginTop="5dp"
                android:fontFamily="@font/righteous"
                android:text="CRASHWARE"
                android:textColor="@color/azul"
                android:textSize="25sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/imgLayoutLogo"
                app:layout_constraintTop_toTopOf="@id/imgLayoutLogo"/>

            <!-- Sininho -->
            <ImageView
                android:id="@+id/layoutSino"
                android:layout_width="30dp"
                android:layout_height="35dp"
                android:layout_marginTop="15dp"
                android:layout_marginEnd="20dp"
                android:contentDescription="logo"
                android:src="@drawable/sino_icon"
                app:layout_constraintEnd_toEndOf="@id/header"
                app:layout_constraintTop_toTopOf="@id/header"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Titulo Software -->
        <LinearLayout
            android:id="@+id/NomeModuloH"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:outlineProvider="background"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/header">

            <!-- Imagem Hardware -->
            <ImageView
                android:id="@+id/imgHardwareAula"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:src="@drawable/hardware_icon"
                app:tint="@color/verde" />

            <!-- Escrito Hardware -->
            <TextView
                android:id="@+id/txtHardware"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_marginTop="-5dp"
                android:fontFamily="@font/inter_extrabold"
                android:text="Hardware"
                android:textAlignment="center"
                android:textColor="@color/verde"
                android:textSize="50dp" />
        </LinearLayout>

        <!-- Card Introdução -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cardIntroducaoH"
            android:layout_width="340dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:padding="20dp"
            android:background="@drawable/bg_card"
            app:layout_constraintTop_toBottomOf="@id/NomeModuloH"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Escrito Introdução -->
            <TextView
                android:id="@+id/txtTituloModulo1H"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="-5dp"
                android:fontFamily="@font/inter_extrabold"
                android:text="Introdução"
                android:textAlignment="center"
                android:textColor="@color/azul"
                android:textSize="20sp"
                app:layout_constraintEnd_toEndOf="@id/cardIntroducaoH"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/cardIntroducaoH" />

            <!-- Barra -->
            <View
                android:id="@+id/barraM1H"
                android:layout_width="280dp"
                android:layout_height="1dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="16dp"
                android:background="#0F172A"
                app:layout_constraintTop_toBottomOf="@id/txtTituloModulo1H"
                app:layout_constraintStart_toStartOf="@id/cardIntroducaoH"
                app:layout_constraintEnd_toEndOf="@id/cardIntroducaoH"/>

            <!-- Imagem Livro -->
            <ImageView
                android:id="@+id/imgLivro1M1H"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="26dp"
                android:layout_marginTop="10dp"
                android:src="@drawable/livro2_icon"
                app:layout_constraintEnd_toStartOf="@+id/txtTituloAula1M1H"
                app:layout_constraintStart_toStartOf="@id/cardIntroducaoH"
                app:layout_constraintTop_toBottomOf="@id/barraM1H" />

            <!-- Título Aula -->
            <TextView
                android:id="@+id/txtTituloAula1M1H"
                android:layout_width="240dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="9dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="24dp"
                android:fontFamily="@font/battambang"
                android:text="Motivação e Mentalidade"
                android:textColor="@color/azul"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="@id/cardIntroducaoH"
                app:layout_constraintStart_toEndOf="@+id/imgLivro1M1H"
                app:layout_constraintTop_toBottomOf="@id/barraM1H" />

            <!-- Imagem Livro -->
            <ImageView
                android:id="@+id/imgLivro2M1H"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="26dp"
                android:layout_marginTop="10dp"
                android:src="@drawable/livro2_icon"
                app:layout_constraintEnd_toStartOf="@+id/txtTituloAula2M1H"
                app:layout_constraintStart_toStartOf="@id/cardIntroducaoH"
                app:layout_constraintTop_toBottomOf="@id/imgLivro1M1H" />

            <!-- Título Aula -->
            <TextView
                android:id="@+id/txtTituloAula2M1H"
                android:layout_width="240dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="9dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="24dp"
                android:fontFamily="@font/battambang"
                android:text="Como vai funcionar esse curso?"
                android:textColor="@color/azul"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="@id/cardIntroducaoH"
                app:layout_constraintStart_toEndOf="@+id/imgLivro2M1H"
                app:layout_constraintTop_toBottomOf="@id/txtTituloAula1M1H" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Card Fundamentos de Hardware -->
        <androidx.constraintlayout.widget.ConstraintLayout
