                app:layout_constraintStart_toStartOf="@id/cardFundamentosHardware"
                app:layout_constraintTop_toBottomOf="@id/barraM2H" />

            <!-- Título Aula -->
            <TextView
                android:id="@+id/txtTituloAula1M2H"
                android:layout_width="240dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="9dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="24dp"
                android:fontFamily="@font/battambang"
                android:text="Introdução ao Hardware"
