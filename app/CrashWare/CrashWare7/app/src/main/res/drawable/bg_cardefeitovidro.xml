<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Gradiente da bordda -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FAFAFA"
                android:centerColor="#C0C0C0"
                android:endColor="#EFEFEF"
                android:centerX="0.72"
                android:angle="135"
                android:type="linear"/>
            <corners android:radius="18dp" />
        </shape>
    </item>

    <!-- Manter a mesma cor do fundo -->
    <item
        android:bottom="3dp"
        android:left="3dp"
        android:right="3dp"
        android:top="3dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/bg_vidro_transparente" />
            <corners android:radius="15dp" />
        </shape>
    </item>

    <!-- Faz a "falsa transparencia" -->
    <item
        android:bottom="3dp"
        android:left="3dp"
        android:right="3dp"
        android:top="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#25FFFFFF" />
            <corners android:radius="15dp" />
        </shape>
    </item>
</layer-list>