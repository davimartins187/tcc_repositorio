<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.CrashWare" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/branco</item>
        <item name="colorOnPrimary">@color/verde</item>

        <item name="colorSecondary">@color/fundo_claro</item>
        <item name="colorOnSecondary">@color/preto</item>

        <item name="android:windowBackground">@color/fundo_claro</item>

        <item name="colorSurface">@color/branco</item>
        <item name="colorOnSurface">@color/texto_modoclaro</item>

        <item name="colorPrimarySurface">#20FFFFFF</item>
        <item name="colorOnPrimarySurface">#500F172A</item>

        <item name="colorSecondaryContainer">#303F4552</item>
