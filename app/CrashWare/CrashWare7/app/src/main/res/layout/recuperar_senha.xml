<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main3"
    android:fillViewport="true"
    android:background="?attr/android:windowBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Header -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:layout_marginTop="15dp"
            android:background="@drawable/bg_gradiendtelasiniciais"
            android:elevation="10dp"
            app:layout_constraintEnd_toStartOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Logo -->
            <ImageView
                android:id="@+id/imgLayoutLogo"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:contentDescription="logo"
                android:src="@drawable/logo_icon"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="@id/header"
                app:layout_constraintTop_toTopOf="@id/header" />

            <!-- Nome do App -->
            <TextView
                android:id="@+id/txtNomeApp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                android:fontFamily="@font/orbitron_extrabold"
                android:text="CRASHWARE"
                android:textColor="@color/branco"
                android:textSize="34sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/imgLayoutLogo"
                app:layout_constraintTop_toTopOf="@id/header" />

            <!-- Slogan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="22dp"
                android:layout_marginEnd="19dp"
                android:layout_marginBottom="31dp"
                android:fontFamily="@font/righteous"
                android:text="A TECNOLOGIA NÃO É MÁGICA, É LÓGICA. "
                android:textColor="@color/branco"
                android:textSize="13sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/imgLayoutLogo"
                app:layout_constraintTop_toBottomOf="@id/txtNomeApp" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cardEfeitoVidro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="80dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_cardefeitovidro"
            android:elevation="10dp"
            android:paddingBottom="25dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/header">

                <!-- Título -->
                <TextView
                    android:id="@+id/txtRecSenha"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Redefinir SENHA"
                    android:textAllCaps="true"
                    android:fontFamily="@font/righteous"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/cardEfeitoVidro" />

                <!-- Métodos de Recuperação -->
                <RadioGroup
                    android:id="@+id/grupoOpcoes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="30dp"
                    android:layout_marginTop="25dp"
                    app:layout_constraintTop_toBottomOf="@+id/txtRecSenha">

                    <RadioButton
                        android:id="@+id/radioEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/righteous"
                        android:text="RECEBER CÓDIGO PELO E-MAIL"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <RadioButton
                        android:layout_marginTop="-10dp"
                        android:id="@+id/radioTelefone"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:text="RECEBER CÓDIGO PELO TELEFONE"
                        android:fontFamily="@font/righteous"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                </RadioGroup>

                <!-- Titulo Email -->
                <TextView
                    android:id="@+id/txtTituloEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="1dp"
                    android:layout_marginTop="20dp"
                    android:fontFamily="@font/righteous"
                    android:text="E-MAIL"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="18sp"
                    app:layout_constraintStart_toStartOf="@id/txtEmailRec"
                    app:layout_constraintTop_toBottomOf="@+id/grupoOpcoes"/>

                <!-- Campo Email -->
                <EditText
                    android:id="@+id/txtEmailRec"
                    android:layout_width="310dp"
                    android:layout_height="48dp"
                    android:layout_marginHorizontal="32dp"
                    android:layout_marginTop="2dp"
                    android:background="@drawable/bg_edittext_borda"
                    android:hint="seu@email.com"
                    android:fontFamily="@font/pt_sans_caption_bold"
                    android:textColor="#000000"
                    android:textColorHint="@color/hint_modoclaro"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/txtTituloEmail" />

                <!-- Botão de Enviar -->
                <Button
                    android:id="@+id/btnRecSenha"
                    android:layout_width="260dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="25dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_botaosborda"
                    android:text="ENVIAR"
                    app:backgroundTint="@null"
                    app:backgroundTintMode="add"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:fontFamily="@font/righteous"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/txtEmailRec" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Lembrou sua senha? -->
        <TextView
            android:id="@+id/txtLembrou"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="90dp"
            android:layout_marginTop="10dp"
            android:text="Lembrou sua senha?"
            android:fontFamily="@font/righteous"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cardEfeitoVidro" />

        <!-- Texto Entrar -->
        <TextView
            android:id="@+id/txtEntrarLembrou"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:fontFamily="@font/righteous"
            android:text="ENTRAR"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp"
            app:layout_constraintStart_toEndOf="@+id/txtLembrou"
            app:layout_constraintTop_toTopOf="@+id/txtLembrou" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:layout_marginTop="-2dp"
            android:background="?attr/colorOnSurface"
            app:layout_constraintEnd_toEndOf="@id/txtEntrarLembrou"
            app:layout_constraintStart_toStartOf="@id/txtEntrarLembrou"
            app:layout_constraintTop_toBottomOf="@id/txtEntrarLembrou" />

        <View
            android:id="@+id/espaco_nav_bar"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            app:layout_constraintTop_toBottomOf="@id/txtLembrou" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>