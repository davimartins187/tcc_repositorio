<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fundo_claro">

    <!-- Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:background="@color/branco"
        android:elevation="10dp"
        app:layout_constraintEnd_toStartOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/addAnotacao"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginStart="20dp"
            android:padding="5dp"
            android:background="@drawable/bg_voltar"
            app:layout_constraintTop_toTopOf="@id/header"
            app:layout_constraintStart_toStartOf="parent">

            <!-- Adicionar Anotacao -->
            <ImageView
                android:id="@+id/imgVoltarNovaAnotacao"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/seta_icon"
                app:layout_constraintStart_toStartOf="@id/addAnotacao"
                app:layout_constraintTop_toTopOf="@id/addAnotacao" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/txtVoltar"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="10dp"
            android:layout_marginTop="5dp"
            android:fontFamily="@font/righteous"
            android:text="Voltar ao conteúdo"
            android:textColor="@color/azul"
            android:textSize="24sp"
            app:layout_constraintStart_toEndOf="@id/addAnotacao"
            app:layout_constraintTop_toTopOf="@id/addAnotacao" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/conteudo"
            android:layout_width="match_parent"
            android:layout_marginTop="20dp"
            android:layout_height="wrap_content"
            android:paddingBottom="20dp">

            <TextView
                android:id="@+id/txtTituloAulaExercicios"
                android:layout_width="350dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp"
                android:fontFamily="@font/battambang_bold"
                android:lineSpacingExtra="-10sp"
                android:text="Como vai funcionar esse curso?"
                android:textColor="@color/azul"
                android:textSize="22sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/conteudo" />

            <!-- Barra de Progresso -->
            <ProgressBar
                android:id="@+id/BarraProgressoNivel"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="300dp"
                android:layout_height="15dp"
                android:layout_marginStart="45dp"
                android:layout_marginTop="5dp"
                android:max="500"
                android:progress="150"
                android:indeterminate="false"
                android:progressDrawable="@drawable/bg_barraprogresso"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/txtTituloAulaExercicios" />

            <!-- Porcentagem -->
            <TextView
                android:id="@+id/txtPorcentagem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/battambang_bold"
                android:layout_marginStart="5dp"
                android:text="30%"
                android:textColor="@color/azul"
                android:textSize="18sp"
                app:layout_constraintStart_toEndOf="@id/BarraProgressoNivel"
                app:layout_constraintTop_toTopOf="@id/BarraProgressoNivel"
                app:layout_constraintBottom_toBottomOf="@id/BarraProgressoNivel"/>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardExercicio"
                android:layout_width="360dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:paddingBottom="25dp"
                android:paddingLeft="20dp"
                android:paddingRight="20dp"
                android:background="@drawable/bg_cards"
                app:layout_constraintTop_toBottomOf="@id/BarraProgressoNivel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/txtPergunta"
                    android:layout_width="320dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:fontFamily="@font/inter_extrabold"
                    android:text="Qual é o objetivo principal do curso apresentado no CrashWare?"
                    android:textAlignment="center"
                    android:textColor="@color/azul"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="@id/cardExercicio"
                    app:layout_constraintStart_toStartOf="@id/cardExercicio"
                    app:layout_constraintTop_toTopOf="@id/cardExercicio" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cardExercicio1"
                    android:layout_width="320dp"
                    android:layout_height="65dp"
                    android:layout_marginTop="20dp"
                    android:paddingBottom="10dp"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:background="@drawable/bg_cards"
                    app:layout_constraintTop_toBottomOf="@id/txtPergunta"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/selecionar1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="15dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/btn_alternativa"
                        app:layout_constraintTop_toTopOf="@id/cardExercicio1"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintBottom_toBottomOf="@id/cardExercicio1">
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <TextView
                        android:id="@+id/txtQuestao1"
                        android:layout_width="260dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:fontFamily="@font/inter_semibold"
                        android:text="Ensinar apenas a montar computadores"
                        android:textColor="@color/azul"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/selecionar1"
                        app:layout_constraintTop_toTopOf="@id/selecionar1"
                        app:layout_constraintBottom_toBottomOf="@id/selecionar1"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cardExercicio2"
                    android:layout_width="320dp"
                    android:layout_height="65dp"
                    android:layout_marginTop="20dp"
                    android:paddingBottom="10dp"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:background="@drawable/bg_cards"
                    app:layout_constraintTop_toBottomOf="@id/cardExercicio1"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/selecionar2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="15dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/btn_alternativa"
                        app:layout_constraintTop_toTopOf="@id/cardExercicio2"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintBottom_toBottomOf="@id/cardExercicio2">
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <TextView
                        android:id="@+id/txtQuestao2"
                        android:layout_width="260dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:fontFamily="@font/inter_semibold"
                        android:text="Ensinar apenas programação"
                        android:textColor="@color/azul"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/selecionar2"
                        app:layout_constraintTop_toTopOf="@id/selecionar2"
                        app:layout_constraintBottom_toBottomOf="@id/selecionar2"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cardExercicio3"
                    android:layout_width="320dp"
                    android:layout_height="65dp"
                    android:layout_marginTop="20dp"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:paddingBottom="10dp"
                    android:background="@drawable/bg_cards"
                    app:layout_constraintTop_toBottomOf="@id/cardExercicio2"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/selecionar3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="15dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/btn_alternativa"
                        app:layout_constraintTop_toTopOf="@id/cardExercicio3"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintBottom_toBottomOf="@id/cardExercicio3">
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <TextView
                        android:id="@+id/txtQuestao3"
                        android:layout_width="260dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:fontFamily="@font/inter_semibold"
                        android:text="Ensinar os fundamentos de forma clara e progressiva"
                        android:textColor="@color/azul"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/selecionar3"
                        app:layout_constraintTop_toTopOf="@id/selecionar3"
                        app:layout_constraintBottom_toBottomOf="@id/selecionar3"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cardExercicio4"
                    android:layout_width="320dp"
                    android:layout_height="65dp"
                    android:layout_marginTop="20dp"
                    android:paddingBottom="10dp"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:background="@drawable/bg_cards"
                    app:layout_constraintTop_toBottomOf="@id/cardExercicio3"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/selecionar4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="15dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/btn_alternativa"
                        app:layout_constraintTop_toTopOf="@id/cardExercicio4"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintBottom_toBottomOf="@id/cardExercicio4">
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <TextView
                        android:id="@+id/txtQuestao4"
                        android:layout_width="260dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:fontFamily="@font/inter_semibold"
                        android:text="Ensinar somente manutenção avançada"
                        android:textColor="@color/azul"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/selecionar4"
                        app:layout_constraintTop_toTopOf="@id/selecionar4"
                        app:layout_constraintBottom_toBottomOf="@id/selecionar4"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <Button
                android:id="@+id/btnProximaQuestao"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginTop="25dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/btn_exercicios"
                android:fontFamily="@font/righteous"
                android:text="Próxima Questão"
                android:textAllCaps="true"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                app:backgroundTint="@null"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardExercicio" />

            <View
                android:id="@+id/espaco_nav_bar"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                app:layout_constraintTop_toBottomOf="@id/btnProximaQuestao" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>