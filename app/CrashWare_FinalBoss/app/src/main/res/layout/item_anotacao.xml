<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:id="@+id/cardAnotacao"
    android:layout_width="340dp"
    android:layout_height="wrap_content"
    android:layout_marginTop="20dp"
    android:layout_marginBottom="10dp"
    android:layout_gravity="center"
    android:padding="20dp"
    android:background="@drawable/bg_cardanotacao">

    <!-- TITULO -->
    <TextView
        android:id="@+id/txtTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:fontFamily="@font/righteous"
        android:text="TITULO"
        android:textColor="@color/azul"
        android:textSize="16sp"
        android:textStyle="bold"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- DATA -->
    <TextView
        android:id="@+id/txtdata"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:fontFamily="@font/righteous"
        android:text="16/04/2026"
        android:textColor="@color/azul"
        android:textSize="14sp"
        android:textStyle="bold"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- LINHA -->
    <View
        android:id="@+id/barraAnotacao"
        android:layout_width="0dp"
        android:layout_height="1dp"

        android:layout_marginTop="10dp"
        android:background="@color/azul"

        app:layout_constraintTop_toBottomOf="@id/txtTitulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- CONTEUDO -->
    <TextView
        android:id="@+id/txtConteudo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"

        android:layout_marginTop="10dp"

        android:fontFamily="@font/righteous"
        android:text="CONTEUDO"
        android:textColor="@color/azul"
        android:textSize="14sp"

        app:layout_constraintTop_toBottomOf="@id/barraAnotacao"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>