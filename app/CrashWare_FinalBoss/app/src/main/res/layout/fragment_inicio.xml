<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/fundo_claro">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Header -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/branco"
            android:elevation="10dp"
            android:paddingLeft="20dp"
            android:paddingTop="15dp"
            android:paddingRight="20dp"
            android:paddingBottom="10dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Foto do Usuário-->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgFotoInicio"
                android:layout_width="85dp"
                android:layout_height="85dp"
                android:padding="2dp"
                android:scaleType="centerCrop"
                app:layout_constraintStart_toStartOf="@id/header"
                app:layout_constraintTop_toTopOf="@id/header"
                app:shapeAppearanceOverlay="@style/CircleImage"
                app:strokeColor="#111827"
                app:strokeWidth="1dp" />

            <!--Nome do Usuário -->
            <TextView
                android:id="@+id/txtNomeInicio"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:fontFamily="@font/righteous"
                android:text=""
                android:textColor="#0F172A"
                android:textSize="28sp"
                app:layout_constraintStart_toEndOf="@id/imgFotoInicio"
                app:layout_constraintTop_toTopOf="@id/imgFotoInicio" />

            <!-- Sininho -->
            <ImageView
                android:id="@+id/layoutSino"
                android:layout_width="30dp"
                android:layout_height="35dp"
                android:contentDescription="logo"
                android:src="@drawable/sino_icon"
                app:layout_constraintEnd_toEndOf="@id/header"
                app:layout_constraintTop_toTopOf="@id/txtNomeInicio" />

            <!-- Nível do Usuário -->
            <TextView
                android:id="@+id/txtNivelInicio"
                android:layout_width="0dp"
                android:layout_marginTop="15dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/righteous"
                android:text="NÍVEL 8"
                android:textColor="#0F172A"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="@id/txtNomeInicio"
                app:layout_constraintTop_toBottomOf="@id/txtNomeInicio" />

            <!-- Barra de Progresso -->
            <ProgressBar
                android:id="@+id/BarraProgressoNivel"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="15dp"
                android:max="500"
                android:progress="350"
                android:indeterminate="false"
                android:progressDrawable="@drawable/bg_barraprogresso"
                app:layout_constraintEnd_toEndOf="@+id/layoutSino"
                app:layout_constraintStart_toStartOf="@id/txtNivelInicio"
                app:layout_constraintTop_toBottomOf="@id/txtNivelInicio" />

            <!--XP do usuário -->
            <TextView
                android:id="@+id/txtXPInicio"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/righteous"
                android:text="400/500 xp"
                android:textAllCaps="true"
                android:textColor="#0F172A"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="@id/layoutSino"
                app:layout_constraintTop_toTopOf="@id/txtNivelInicio" />

        </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardAulaRetomar"
                android:layout_width="370dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:paddingBottom="12dp"
                android:background="@drawable/bg_cardmodulo"
                app:layout_constraintTop_toBottomOf="@id/header"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/gradientHardwareRetomar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp"
                    android:elevation="10dp"
                    android:background="@drawable/bg_gradientehardware"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <!-- Módulo Hardware -->
                    <TextView
                        android:id="@+id/txtModuloHome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="60dp"
                        android:layout_marginStart="15dp"
                        android:fontFamily="@font/battambang"
                        android:text="Hardware"
                        android:textAlignment="center"
                        android:textColor="@color/branco"
                        android:textSize="14sp"
                        app:layout_constraintStart_toStartOf="@id/gradientHardwareRetomar"
                        app:layout_constraintTop_toTopOf="@id/gradientHardwareRetomar" />

                    <!-- Barra -->
                    <TextView
                        android:id="@+id/txtBarra"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="60dp"
                        android:layout_marginStart="5dp"
                        android:fontFamily="@font/battambang"
                        android:text="|"
                        android:textAlignment="center"
                        android:textColor="@color/branco"
                        android:textSize="14sp"
                        app:layout_constraintStart_toEndOf="@id/txtModuloHome"
                        app:layout_constraintTop_toTopOf="@id/gradientHardwareRetomar" />

                    <!-- Aula do Módulo -->
                    <TextView
                        android:id="@+id/txtAulaHome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:fontFamily="@font/battambang"
                        android:text="Aula 1"
                        android:textAlignment="center"
                        android:textColor="@color/branco"
                        android:textSize="14sp"
                        app:layout_constraintStart_toEndOf="@id/txtBarra"
                        app:layout_constraintTop_toTopOf="@id/gradientHardwareRetomar" />

                    <!-- Título da Aula -->
                    <TextView
                        android:id="@+id/txtTituloAulaHome"
                        android:layout_width="300dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/righteous"
                        android:text="Como vai funcionar esse curso?"
                        android:textAlignment="viewStart"
                        android:textColor="@color/branco"
                        android:textSize="20sp"
                        app:layout_constraintStart_toStartOf="@id/txtModuloHome"
                        app:layout_constraintTop_toBottomOf="@id/txtModuloHome" />

                    <!-- Botão Retomar -->
                    <Button
                        android:id="@+id/btnRetomar"
                        android:layout_width="200dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_gradientehardware"
                        app:backgroundTint="@color/branco"
                        app:backgroundTintMode="add"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="10dp"
                        android:fontFamily="@font/inter_bold"
                        android:text="Retomar"
                        android:textColor="#39CA20"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="@id/gradientHardwareRetomar"
                        app:layout_constraintStart_toStartOf="@id/gradientHardwareRetomar"
                        app:layout_constraintTop_toBottomOf="@id/txtTituloAulaHome" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Próximo Módulo -->
                <TextView
                    android:id="@+id/txtProxModulo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/righteous"
                    android:text="Próximo Módulo"
                    android:textColor="#555B68"
                    android:textSize="18sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/gradientHardwareRetomar" />

                <!-- Card Título Próximo Módulo -->
                <LinearLayout
                    android:id="@+id/cardModulo"
                    android:layout_width="325dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:background="@drawable/bg_cardmod"
                    android:orientation="horizontal"
                    app:layout_constraintTop_toBottomOf="@id/txtProxModulo"
                    app:layout_constraintBottom_toBottomOf="@id/cardAulaRetomar"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent">

                    <!-- Imagem Hardware -->
                    <ImageView
                        android:id="@+id/ivModulo"
                        android:layout_width="30dp"
                        android:layout_height="25dp"
                        android:layout_marginStart="5dp"
                        android:src="@drawable/hardware_icon"
                        app:layout_constraintStart_toStartOf="@id/cardModulo"
                        app:layout_constraintTop_toTopOf="@id/cardModulo" />

                    <!-- Titulo do Próximo Módulo -->
                    <TextView
                        android:id="@+id/txtModulo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:fontFamily="@font/inter_extrabold"
                        android:text="Introdução ao Hardware"
                        android:textColor="#555B68"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="@id/ivModulo"
                        app:layout_constraintTop_toTopOf="@id/cardModulo" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Suas Trilhas -->
            <TextView
                android:id="@+id/txtSuasTrilhas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/righteous"
                android:text="SUAS TRILHAS"
                android:layout_marginTop="20dp"
                android:textAlignment="viewStart"
                android:textColor="#0F172A"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="@id/cardAulaRetomar"
                app:layout_constraintTop_toBottomOf="@id/cardAulaRetomar" />

                <!-- Card Hardware -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cardModuloHardware"
                    android:layout_width="370dp"
                    android:layout_height="120dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_cards"
                    android:padding="12dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/txtSuasTrilhas">

                    <!-- Imagem Hardware -->
                    <ImageView
                        android:id="@+id/imgHardware"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:src="@drawable/hardwarehome_icon"
                        android:layout_marginTop="2dp"
                        app:layout_constraintStart_toStartOf="@id/cardModuloHardware"
                        app:layout_constraintTop_toTopOf="@id/cardModuloHardware" />

                    <!-- Titulo Hardware -->
                    <TextView
                        android:id="@+id/txtModuloHardware"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:fontFamily="@font/righteous"
                        android:text="Hardware"
                        android:textColor="@color/verde"
                        android:textSize="20sp"
                        app:layout_constraintStart_toEndOf="@id/imgHardware"
                        app:layout_constraintTop_toTopOf="@id/imgHardware" />

                    <!-- Curta Descrição -->
                    <TextView
                        android:id="@+id/txtDescricaoHardware"
                        android:layout_width="260dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="-5dp"
                        android:fontFamily="@font/inter_semibold"
                        android:text="Desvende a arquitetura das máquinas de forma acessível."
                        android:textColor="#555B68"
                        android:textSize="14sp"
                        app:layout_constraintTop_toBottomOf="@id/txtModuloHardware"
                        app:layout_constraintStart_toStartOf="@id/txtModuloHardware"/>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/btnRetomarH"
                        android:layout_width="110dp"
                        android:layout_height="30dp"
                        android:layout_marginTop="5dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/btn_explorarhardware"
                        app:layout_constraintEnd_toEndOf="@id/txtDescricaoHardware"
                        app:layout_constraintTop_toBottomOf="@id/txtDescricaoHardware">

                        <TextView
                            android:id="@+id/txtRetomarH"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:fontFamily="@font/righteous"
                            android:text="Explorar >"
                            android:textAllCaps="true"
                            android:textColor="@color/branco"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="@id/btnRetomarH"
                            app:layout_constraintEnd_toEndOf="@id/btnRetomarH"
                            app:layout_constraintTop_toTopOf="@id/btnRetomarH" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Curta Software -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cardModuloSoftware"
                    android:layout_width="370dp"
                    android:layout_height="120dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_cards"
                    android:padding="12dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/cardModuloHardware">

                    <ImageView
                        android:id="@+id/imgSoftware"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:src="@drawable/softwarehome_icon"
                        android:layout_marginTop="2dp"
                        app:layout_constraintStart_toStartOf="@id/cardModuloSoftware"
                        app:layout_constraintTop_toTopOf="@id/cardModuloSoftware" />

                    <TextView
                        android:id="@+id/txtModuloSoftware"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:fontFamily="@font/righteous"
                        android:text="Software"
                        android:textColor="#0F66B3"
                        android:textSize="20sp"
                        app:layout_constraintStart_toEndOf="@id/imgSoftware"
                        app:layout_constraintTop_toTopOf="@id/imgSoftware" />

                    <TextView
                        android:id="@+id/txtDescricaoSoftware"
                        android:layout_width="260dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="-5dp"
                        android:fontFamily="@font/inter_semibold"
                        android:text="Decifre a linguagem dos sistemas de forma intuitiva."
                        android:textColor="#555B68"
                        android:textSize="14sp"
                        app:layout_constraintTop_toBottomOf="@id/txtModuloSoftware"
                        app:layout_constraintStart_toStartOf="@id/txtModuloSoftware"/>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/btnRetomarS"
                        android:layout_width="110dp"
                        android:layout_height="30dp"
                        android:layout_marginTop="5dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/btn_explorarsoftware"
                        app:layout_constraintEnd_toEndOf="@id/txtDescricaoSoftware"
                        app:layout_constraintTop_toBottomOf="@id/txtDescricaoSoftware">

                        <TextView
                            android:id="@+id/txtRetomarS"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:fontFamily="@font/righteous"
                            android:text="Explorar >"
                            android:textAllCaps="true"
                            android:textColor="@color/branco"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="@id/btnRetomarS"
                            app:layout_constraintEnd_toEndOf="@id/btnRetomarS"
                            app:layout_constraintTop_toTopOf="@id/btnRetomarS" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Card Dias Consecutivos -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cardDiasConsecutivos"
                    android:layout_width="250dp"
                    android:layout_height="120dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_cards"
                    android:padding="12dp"
                    app:layout_constraintStart_toStartOf="@id/cardModuloSoftware"
                    app:layout_constraintTop_toBottomOf="@id/cardModuloSoftware">

                    <ImageView
                        android:id="@+id/imgRaposa"
                        android:layout_width="120dp"
                        android:layout_height="100dp"
                        android:src="@drawable/raposa_icon"
                        app:layout_constraintStart_toStartOf="@id/cardDiasConsecutivos"
                        app:layout_constraintTop_toTopOf="@id/cardDiasConsecutivos" />
                    <TextView
                        android:id="@+id/txtDiasConsecutivos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginEnd="4dp"
                        android:fontFamily="@font/righteous"
                        android:text="58 dias"
                        android:textColor="#555B68"
                        android:textSize="24sp"
                        app:layout_constraintEnd_toEndOf="@id/cardDiasConsecutivos"
                        app:layout_constraintTop_toTopOf="@id/cardDiasConsecutivos" />

                    <TextView
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="-2dp"
                        android:fontFamily="@font/inter_semibold"
                        android:text="consecutivos de ofensiva "
                        android:textAlignment="textEnd"
                        android:textColor="#555B68"
                        android:textSize="14sp"
                        app:layout_constraintEnd_toEndOf="@id/txtDiasConsecutivos"
                        app:layout_constraintTop_toBottomOf="@id/txtDiasConsecutivos" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Card Dias Consecutivos -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cardAulasConcluidas"
                    android:layout_width="110dp"
                    android:layout_height="120dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_cards"
                    android:padding="12dp"
                    app:layout_constraintEnd_toEndOf="@id/cardModuloSoftware"
                    app:layout_constraintStart_toEndOf="@id/cardDiasConsecutivos"
                    app:layout_constraintTop_toBottomOf="@id/cardModuloSoftware">

                    <ImageView
                        android:id="@+id/imgAulasConcluidas"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/aulasconcluidas_icon"
                        app:layout_constraintEnd_toEndOf="@id/cardAulasConcluidas"
                        app:layout_constraintStart_toStartOf="@id/cardAulasConcluidas"
                        app:layout_constraintTop_toTopOf="@id/cardAulasConcluidas" />

                    <TextView
                        android:id="@+id/txtNumeroAulasConcluidas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/righteous"
                        android:text="1"
                        android:textColor="#555B68"
                        android:textSize="20sp"
                        app:layout_constraintTop_toBottomOf="@id/imgAulasConcluidas"
                        app:layout_constraintEnd_toEndOf="@id/cardAulasConcluidas"
                        app:layout_constraintStart_toStartOf="@id/cardAulasConcluidas"/>

                    <TextView
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="-5dp"
                        android:fontFamily="@font/inter_semibold"
                        android:text="Aulas Concluídas"
                        android:textAlignment="center"
                        android:textColor="#555B68"
                        android:textSize="14sp"
                        app:layout_constraintEnd_toEndOf="@id/cardAulasConcluidas"
                        app:layout_constraintStart_toStartOf="@id/cardAulasConcluidas"
                        app:layout_constraintTop_toBottomOf="@id/txtNumeroAulasConcluidas" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <View
                    android:id="@+id/espaco_nav_bar"
                    android:layout_width="match_parent"
                    android:layout_height="20dp"
                    app:layout_constraintTop_toBottomOf="@id/cardAulasConcluidas" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>